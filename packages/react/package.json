{
  "name": "@feedock/react",
  "version": "0.7.0",
  "description": "React SDK to embed a Feedock feedback board, roadmap, and changelog directly in your app.",
  "license": "MIT",
  "author": "Feedock",
  "homepage": "https://feedock.com/developers#react-sdk",
  "bugs": {
    "url": "https://feedback.feedock.com"
  },
  "keywords": [
    "feedock",
    "feedback",
    "feature-requests",
    "roadmap",
    "changelog",
    "react",
    "widget",
    "saas"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "api:probe": "esbuild dist/index.js --bundle --format=esm --outfile=.api-probe.mjs --external:react --external:react-dom --log-level=error && node --input-type=module -e \"import('./.api-probe.mjs').then(m=>console.log(Object.keys(m).sort().join('\\n')))\" && rm -f .api-probe.mjs",
    "clean": "rm -rf dist .turbo .api-probe.mjs"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@types/react": "^19",
    "esbuild": "^0.25",
    "eslint": "^9",
    "eslint-plugin-react-hooks": "^7.1.1",
    "react": "^19",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/feedockapp/feedock-js.git",
    "directory": "packages/react"
  }
}
